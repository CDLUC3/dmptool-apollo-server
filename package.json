{
  "name": "dmsp_apollo",
  "version": "1.0.0",
  "description": "Prototype backend for the new DMSP system",
  "main": "index.js",
  "scripts": {
    "compile": "tsc",
    "copy-graphql": "mkdir ./dist/schemas && cp ./src/schemas/*.graphql ./dist/schemas/",
    "generate": "graphql-codegen",
    "lint": "npx eslint . --ignore-pattern dist/ --ignore-pattern src/types.ts",
    "test": "jest --coverage",
    "test-no-db": "jest --testPathIgnorePatterns=\"src/datasources/__tests__/relatedWorksTables.spec.ts\"",
    "build": "rm -rf ./dist && npm run generate && npm run compile",
    "dev": "ts-node-dev --respawn ./src/index.ts",
    "start": "npm run build && nodemon ./dist/index.js",
    "aws_start": "node ./dist/index.js",
    "prepare": "is-ci || npx husky install",
    "trivy-high": "sh ./src/scripts/trivy-high.sh",
    "trivy-med": "sh ./src/scripts/trivy-med.sh",
    "trivy-all": "npm run trivy-high && npm run trivy-med",
    "init-localstack": "localstack-setup/init-aws.sh",
    "re3data:sync": "ts-node ./data-migrations/re3data-os-populate.ts"
  },
  "compilerOptions": {
    "sourceMap": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/CDLUC3/dmsp_backend_prototype.git"
  },
  "author": "University of California Curation Center (UC3)<dmptool@ucop.edu>",
  "keywords": [],
  "license": "MIT",
  "engines": {
    "node": ">=22.15.0",
    "npm": ">=11.3.0"
  },
  "dependencies": {
    "@apollo/datasource-rest": "^6.4.1",
    "@apollo/server": "^5.4.0",
    "@apollo/utils.keyvadapter": "^4.0.1",
    "@as-integrations/express5": "^1.1.2",
    "@aws-sdk/client-dynamodb": "^3.983.0",
    "@aws-sdk/client-ssm": "^3.983.0",
    "@aws-sdk/credential-providers": "^3.983.0",
    "@aws-sdk/util-dynamodb": "^3.983.0",
    "@dmptool/types": "^3.1.0",
    "@dmptool/utils": "^1.0.40",
    "@elastic/ecs-pino-format": "^1.5.0",
    "@graphql-tools/merge": "^9.1.7",
    "@graphql-tools/mock": "^9.1.5",
    "@graphql-tools/schema": "^10.0.31",
    "@keyv/redis": "^5.1.6",
    "@node-oauth/express-oauth-server": "^4.1.4",
    "@opensearch-project/opensearch": "^3.5.1",
    "@xmldom/xmldom": "^0.8.11",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.4",
    "cookie-parser": "^1.4.7",
    "date-fns": "^4.1.0",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "express-jwt": "^8.5.1",
    "graphql": "^16.12.0",
    "graphql-tag": "^2.12.6",
    "http-cache-semantics": "^4.2.0",
    "is-ci": "^4.1.0",
    "jsonwebtoken": "^9.0.3",
    "keyv": "^5.6.0",
    "mysql2": "^3.16.1",
    "nodemailer": "^7.0.12",
    "pino": "^9.14.0",
    "uuid": "^9.0.1",
    "uuid-random": "^1.3.2",
    "xpath": "^0.0.34"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@graphql-codegen/cli": "^6.1.1",
    "@graphql-codegen/typescript": "^5.0.7",
    "@graphql-codegen/typescript-resolvers": "^5.1.5",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-oauth-server": "^2.0.10",
    "@types/jest": "^30.0.0",
    "@types/oauth2-server": "^3.0.18",
    "@types/pino": "^7.0.5",
    "@types/supertest": "^6.0.3",
    "assert": "^2.1.0",
    "casual": "^1.6.2",
    "eslint": "^9.39.2",
    "globals": "^17.0.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-expect-message": "^1.1.3",
    "jest-mock": "^30.2.0",
    "nock": "^14.0.10",
    "nodemon": "^3.1.11",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.1"
  }
}
