# syntax = docker/dockerfile:1

# Stage 1: Dependencies
# -----------------------------
# preferred node version chosen here (22.22-alpine3.23 as of 02/10/2026)
FROM public.ecr.aws/docker/library/node:22.22-alpine3.23 as deps
WORKDIR /app

# Set production environment
ENV CI=true

# Copy package.json and package-lock.json
# to the /app working directory
COPY package*.json ./

# Install dependencies in /app (excluding devDependencies)
RUN npm ci

#Stage 2: Builder
# -----------------------------
FROM public.ecr.aws/docker/library/node:22.22-alpine3.23 as builder
WORKDIR /app

# Set production environment
ENV CI=true

# Copy dependencies from deps stage
COPY --from=deps /app/node_modules ./node_modules
COPY . .

# Build the application
RUN npm run build

# Prune node_modules to only production-ready ones AFTER build
RUN npm prune --omit=dev && npm cache clean --force

# Remove all unecessary test and mock files from the distribution
RUN rm -rf dist/__tests__ \
           dist/__mocks__ \
           dist/**/__tests__ \
           dist/**/__mocks__

# Stage 3: Runner
# -----------------------------
FROM public.ecr.aws/docker/library/node:22.22-alpine3.23 as runner
WORKDIR /app

ENV NODE_ENV=production
ENV HOSTNAME 0.0.0.0
EXPOSE 4000

RUN apk add --no-cache bash

# Only copy the compiled code and the pruned node_modules
COPY --from=builder /app/dist ./dist
COPY --from=builder /app/node_modules ./node_modules

# Start the application
CMD ["node", "dist/index.js"]
