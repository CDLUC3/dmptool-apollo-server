{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "enabledManagers": [
    "npm"
  ],
  "baseBranches": [
    "development"
  ],
  "ignorePaths": [
    ".github",
    ".husky",
    "data-migrations/**",
    "docs/**",
    "lambdas/**"
  ],
  "minimumReleaseAge": "3 days",
  "abandonmentThreshold": "2 years",
  "bumpVersion": "minor",
  "schedule": [
    "* * * * 7"
  ]
}
